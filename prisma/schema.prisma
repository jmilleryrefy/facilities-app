// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum RequestCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  CLEANING
  SECURITY
  FURNITURE
  IT_EQUIPMENT
  STRUCTURAL
  LANDSCAPING
  OTHER
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String            @unique
  emailVerified   DateTime?
  image           String?         @db.Text
  role            Role              @default(USER)
  department      String?
  jobTitle        String?
  accounts         Account[]
  facilityRequests FacilityRequest[]  @relation("requester")
  assignedRequests FacilityRequest[]  @relation("assignee")
  responses        RequestResponse[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  ext_expires_in    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model FacilityRequest {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation("requester", fields: [userId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?             @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  location    String
  description String            @db.Text
  category    RequestCategory   @default(OTHER)
  severity    Severity          @default(MEDIUM)
  status      RequestStatus     @default(PENDING)
  responses   RequestResponse[]
  attachments Attachment[]
  auditLogs   AuditLog[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([assigneeId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@map("facility_requests")
}

model Attachment {
  id        String          @id @default(cuid())
  requestId String
  request   FacilityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fileName  String
  fileType  String
  fileSize  Int
  fileData  Bytes           @db.LongBlob
  createdAt DateTime        @default(now())

  @@index([requestId])
  @@map("attachments")
}

model RequestResponse {
  id             String          @id @default(cuid())
  requestId      String
  request        FacilityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId       String?
  author         User?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
  message        String          @db.Text
  isAdminResponse Boolean        @default(true)
  createdAt      DateTime        @default(now())

  @@index([requestId])
  @@index([authorId])
  @@map("request_responses")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([requestId])
  @@map("notifications")
}

model AuditLog {
  id        String          @id @default(cuid())
  requestId String
  request   FacilityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?           @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String          // e.g. "created", "updated", "status_changed", "assigned", "cancelled", "commented"
  field     String?         // which field changed, if applicable
  oldValue  String?         @db.Text
  newValue  String?         @db.Text
  createdAt DateTime        @default(now())

  @@index([requestId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}
